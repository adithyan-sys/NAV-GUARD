<?xml version="1.0" encoding="UTF-8"?>
<svg width="144" height="144" viewBox="0 0 144 144" fill="none" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="appBg" x1="0" y1="0" x2="144" y2="144" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#0D3060" />
      <stop offset="100%" stop-color="#071D35" />
    </linearGradient>
    <linearGradient id="appShield" x1="50" y1="10" x2="50" y2="92" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#1A5080" />
      <stop offset="100%" stop-color="#0A2540" />
    </linearGradient>
    <linearGradient id="appPin" x1="50" y1="36" x2="50" y2="66" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#00D48C" />
      <stop offset="100%" stop-color="#009E65" />
    </linearGradient>
    <radialGradient id="glow" cx="25%" cy="20%" r="55%" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#00D48C" stop-opacity="0.14" />
      <stop offset="100%" stop-color="#00D48C" stop-opacity="0" />
    </radialGradient>
    <filter id="glowFilter" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="2" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background -->
  <rect width="144" height="144" rx="32" fill="url(#appBg)"/>
  <rect width="144" height="144" rx="32" fill="url(#glow)"/>
  
  <!-- Border -->
  <rect x="0.75" y="0.75" width="142.5" height="142.5" rx="31.25" fill="none" stroke="#00B87A" stroke-width="1.5" stroke-opacity="0.3"/>
  
  <!-- Shield Icon -->
  <g transform="translate(25.2, 25.2) scale(0.9359999999999999)">
    <path d="M50 10 L84 24 L84 54 C84 73 69 86 50 93 C31 86 16 73 16 54 L16 24 Z" fill="url(#appShield)" />
    <path d="M50 10 L84 24 L84 54 C84 73 69 86 50 93 C31 86 16 73 16 54 L16 24 Z" fill="none" stroke="#00B87A" stroke-width="2" stroke-opacity="0.85" filter="url(#glowFilter)" />
    <path d="M50 36 C43 36 37.5 41.5 37.5 48.5 C37.5 57.5 50 70 50 70 C50 70 62.5 57.5 62.5 48.5 C62.5 41.5 57 36 50 36 Z" fill="white" opacity="0.96" />
    <circle cx="50" cy="48.5" r="7" fill="url(#appPin)" />
    <circle cx="50" cy="48.5" r="2.6" fill="white" />
  </g>
</svg>